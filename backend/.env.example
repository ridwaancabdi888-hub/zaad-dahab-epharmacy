NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/zaad_dahab_pharmacy

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate limiting (auth routes)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Payment gateway webhooks (sandbox — no real Zaad/e-Dahab merchant
# credentials are used; see backend/README.md "Sandbox test scenarios")
ZAAD_WEBHOOK_SECRET=replace-with-a-long-random-secret
EDAHAB_WEBHOOK_SECRET=replace-with-a-long-random-secret
